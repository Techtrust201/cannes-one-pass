# Exemple de configuration E2E — ne pas committer de secrets réels.

# URL de l'application (local ou preview). Si absent, Playwright démarre `npm run dev`.
E2E_BASE_URL=http://127.0.0.1:3000

# Compte dédié aux tests (lecture/écriture selon permissions).
E2E_USER_EMAIL=e2e@example.com
E2E_USER_PASSWORD=change-me

# Base PostgreSQL isolée (branche Neon dédiée ou instance locale).
E2E_DATABASE_URL=postgresql://user:pass@host/e2e_db?sslmode=require

# Identifiant unique par exécution (préfixe E2E- pour nettoyage ciblé).
E2E_RUN_ID=E2E-local-dev

# Obligatoire pour les tests mutatifs (création planning, import, accréditations…).
E2E_ALLOW_WRITES=false

# URL production en lecture seule pour smoke (optionnel).
E2E_SMOKE_BASE_URL=https://cannes-one-pass-r2.vercel.app
