<?xml version="1.0" encoding="utf-8"?>
<!--
  Enterprise Home Screen (EHS) - Zebra TC27
  Profil pilote Palais des Festivals / Cannes One Pass

  Déploiement StageNow :
  FileMgr -> copier ce fichier vers :
  /enterprise/usr/enterprisehomescreen.xml

  Objectif :
  - Afficher Cannes One Pass
  - Afficher WhatsApp Business
  - Masquer les autres applications en mode utilisateur

  Notes :
  - L'URL Cannes One Pass reste volontairement à la racine.
    Si une session existe, l'app peut ouvrir l'espace connecté.
    Sinon, l'auth redirigera vers /login.
  - WhatsApp Business = com.whatsapp.w4b
  - Le mot de passe admin EHS ne doit pas être écrit en clair ici.
    Il doit être défini dans l'interface EHS, puis exporté si besoin.
-->
<config>

    <kiosk>
    </kiosk>

    <applications>
        <link label="Cannes One Pass" url="https://cannes-one-pass-r2.vercel.app" />
        <application label="WhatsApp Business" package="com.whatsapp.w4b" />
    </applications>

    <tools>
    </tools>

    <passwords>
        <admin>0000</admin>
    </passwords>

    <preferences>
        <title>Cannes One Pass</title>
        <kiosk_mode_enabled>0</kiosk_mode_enabled>
        <system_settings_restricted>1</system_settings_restricted>
        <recent_apps_button_disabled>1</recent_apps_button_disabled>
        <recent_apps_access_disabled>1</recent_apps_access_disabled>
        <keyguard_camera_disabled>1</keyguard_camera_disabled>
        <keyguard_search_disabled>1</keyguard_search_disabled>
        <usb_debugging_disabled>1</usb_debugging_disabled>
    </preferences>

</config>